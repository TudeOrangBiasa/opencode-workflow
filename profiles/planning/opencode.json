{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "planning-lead",
  "agent": {
    "planning-lead": {
      "mode": "primary",
      "model": "opencode/hy3-free"
    },
    "product-manager": {
      "mode": "subagent",
      "model": "opencode/hy3-free"
    },
    "ux-researcher": {
      "mode": "subagent",
      "model": "opencode/hy3-free"
    }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "skills": {
    "paths": [
      "./skills"
    ]
  }
}
