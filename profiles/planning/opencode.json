{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_KEY}"
      },
      "models": {
        "claude-fable-5": {},
        "gpt-5.6-sol": {},
        "claude-sonnet-5": {},
        "gpt-5.6-terra": {}
      }
    }
  },
  "default_agent": "planning-lead",
  "agent": {
    "planning-lead": {
      "mode": "primary",
      "model": "9router/gpt-5.6-sol",
      "prompt": "{file:./agents/planning-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "product-manager": "allow",
          "ux-researcher": "allow",
          "explore": "allow"
        },
        "websearch": "deny",
        "webfetch": "deny",
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "caveman": "allow",
          "triage": "allow",
          "to-spec": "allow",
          "to-tickets": "allow",
          "wayfinder": "allow",
          "grilling": "allow",
          "grill-with-docs": "allow",
          "handoff": "allow",
          "write-a-skill": "allow",
          "deep-research": "allow",
          "research": "allow",
          "architecture-decision-records": "allow",
          "improve-codebase-architecture": "allow",
          "domain-modeling": "allow",
          "teach": "allow"
        }
      }
    },
    "product-manager": {
      "mode": "subagent",
      "model": "9router/gpt-5.6-sol",
      "prompt": "{file:./agents/product-manager.md}",
      "permission": {
        "skill": {
          "to-spec": "allow",
          "to-tickets": "allow",
          "handoff": "allow",
          "write-a-skill": "allow"
        }
      }
    },
    "ux-researcher": {
      "mode": "subagent",
      "model": "9router/gpt-5.6-sol",
      "prompt": "{file:./agents/ux-researcher.md}",
      "permission": {
        "skill": {
          "deep-research": "allow",
          "research": "allow",
          "handoff": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md", "../../CODING_STANDARDS.md"],
  "skills": { "paths": ["./skills"] }
}
