{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_KEY}"
      },
      "models": {
        "claude-fable-5": {},
        "gpt-5.6-sol": {},
        "claude-sonnet-5": {},
        "gpt-5.6-terra": {}
      }
    }
  },
  "default_agent": "engineering-lead",
  "agent": {
    "engineering-lead": {
      "mode": "primary",
      "model": "9router/claude-sonnet-5",
      "prompt": "{file:./agents/engineering-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "frontend-dev": "allow",
          "backend-dev": "allow",
          "explore": "allow"
        },
        "websearch": "deny",
        "webfetch": "deny",
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "caveman": "allow",
          "react-patterns": "allow",
          "angular-developer": "allow",
          "ui-to-vue": "allow",
          "accessibility": "allow",
          "nextjs-turbopack": "allow",
          "nuxt4-patterns": "allow",
          "vite-patterns": "allow",
          "design-skill": "allow",
          "laravel": "allow",
          "django": "allow",
          "fastapi-patterns": "allow",
          "api-connector-builder": "allow",
          "backend-patterns": "allow",
          "mcp-server-patterns": "allow",
          "modular-monolith": "allow",
          "implement": "allow",
          "prototype": "allow",
          "containers": "allow",
          "database-patterns": "allow",
          "database-migrations": "allow",
          "database-review": "allow",
          "flox-environments": "allow",
          "shared-hosting-deployment": "allow"
        }
      }
    },
    "frontend-dev": {
      "mode": "subagent",
      "model": "9router/claude-sonnet-5",
      "prompt": "{file:./agents/frontend-dev.md}",
      "permission": {
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "react-patterns": "allow",
          "angular-developer": "allow",
          "ui-to-vue": "allow",
          "accessibility": "allow",
          "nextjs-turbopack": "allow",
          "nuxt4-patterns": "allow",
          "vite-patterns": "allow",
          "design-skill": "allow"
        }
      }
    },
    "backend-dev": {
      "mode": "subagent",
      "model": "9router/claude-sonnet-5",
      "prompt": "{file:./agents/backend-dev.md}",
      "permission": {
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "laravel": "allow",
          "django": "allow",
          "fastapi-patterns": "allow",
          "api-connector-builder": "allow",
          "backend-patterns": "allow",
          "mcp-server-patterns": "allow",
          "tdd": "allow",
          "modular-monolith": "allow",
          "implement": "allow",
          "prototype": "allow",
          "containers": "allow",
          "database-patterns": "allow",
          "database-migrations": "allow",
          "database-review": "allow",
          "flox-environments": "allow",
          "shared-hosting-deployment": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "browser-use": {
      "type": "local",
      "command": ["/home/todayz/.local/share/opencode/browser-use-venv/bin/mcp-browser-use"],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md", "../../CODING_STANDARDS.md"],
  "skills": { "paths": ["./skills"] }
}
