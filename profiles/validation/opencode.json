{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "validation-lead",
  "agent": {
    "validation-lead": {
      "mode": "primary",
      "model": "opencode/hy3-free"
    },
    "qa-engineer": {
      "mode": "subagent",
      "model": "opencode/hy3-free"
    },
    "security-reviewer": {
      "mode": "subagent",
      "model": "opencode/hy3-free"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "skills": {
    "paths": ["./skills"]
  },
  "skill_triggers": {
    "ai-regression-testing": ["AI regression", "regression test", "AI test", "model regression"],
    "tdd": ["TDD", "test-driven", "red-green", "test first", "write test"],
    "code-review": ["code review", "review this", "review PR", "review diff", "review branch"],
    "diagnosing-bugs": ["bug", "broken", "error", "crash", "slow", "regression", "not working"],
    "verify-evidence": ["verify", "evidence", "ship", "ship it", "done", "is it done", "merge", "PR ready", "deploy"],
    "click-path-audit": ["click path", "user flow", "navigation audit", "UX flow"],
    "error-handling": ["error handling", "error case", "edge case", "null check"],
    "production-audit": ["prod readiness", "launch check", "pre-deploy audit", "production check"],
    "team-handoff-quality": ["handoff quality", "delivery summary", "release notes", "changelog"],
    "php-review": ["PHP", "PHP review", "laravel review", "PHP code review"],
    "security-review": ["security", "auth", "secret", "password", "credential", "vulnerability", "security audit"],
    "security-bounty-hunter": ["bug bounty", "CVE", "exploit", "security bounty"],
    "defi-amm-security": ["DeFi", "AMM", "liquidity pool", "flash loan", "DEX security"],
    "evm-token-decimals": ["token decimals", "ERC20", "EVM token", "token standard"],
    "nodejs-keccak256": ["keccak256", "hash", "ethereum hash", "SHA3"],
    "prediction-market-risk-review": ["prediction market", "market risk", "betting platform", "oracle risk"]
  }
}
