{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_KEY}"
      },
      "models": {
        "claude-fable-5": {},
        "oc-go-plan": {},
        "oc-go-eng": {},
        "oc-go-valid": {}
      }
    }
  },
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "9router/claude-fable-5",
      "prompt": "{file:./agents/orchestrator.md}",
      "permission": {
        "task": {
          "*": "deny",
          "explore": "allow",
          "scout": "allow"
        },
        "websearch": "deny",
        "webfetch": "deny",
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "caveman": "allow",
          "memory-dreaming": "allow",
          "workflow-audit": "allow",
          "eval": "allow",
          "codebase-onboarding": "allow",
          "context-budget": "allow",
          "deployment-patterns": "allow",
          "git-workflow": "allow",
          "github-ops": "allow",
          "herdr": "allow",
          "search-first": "allow",
          "skill-author": "allow",
          "setup-matt": "allow",
          "ask-matt": "allow",
          "handoff": "allow",
          "research": "allow",
          "grilling": "allow",
          "verify-evidence": "allow",
          "production-audit": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "command": {
    "spawn": {
      "template": "Run spawn script: `!bash $HOME/.config/opencode-profiles/orchestrator/spawn-team.zsh $ARGUMENTS`",
      "description": "Spawn planning/engineering/validation in Herdr workspace. Usage: /spawn <workspace-name>",
      "agent": "orchestrator"
    }
  },
  "instructions": ["./rules/agents.md", "../../CODING_STANDARDS.md"],
  "skills": { "paths": ["./skills"] }
}
