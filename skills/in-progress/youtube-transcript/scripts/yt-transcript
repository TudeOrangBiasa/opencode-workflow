#!/usr/bin/env python3
"""yt-transcript: extract clean transcript text from a YouTube URL.

Wraps yt-dlp to fetch auto-generated / manual subtitles and returns
deduplicated plain text. Falls back across language priority list.

Usage:
    yt-transcript <youtube-url> [lang-priority] [-o outfile]
    yt-transcript https://youtu.be/dQw4w9WgXcQ
    yt-transcript https://youtu.be/dQw4w9WgXcQ id,en -o transcript.txt

Exit codes:
    0  success
    1  usage error
    2  yt-dlp / network error
    3  no subtitles found for requested languages
"""
from __future__ import annotations

import argparse
import re
import subprocess
import sys
import tempfile
from pathlib import Path

VTT_TAG_RE = re.compile(r"<[^>]+>")
TIMESTAMP_LINE_RE = re.compile(r"^\d{2}:\d{2}:\d{2}\.\d{3}\s+-->\s+\d{2}:\d{2}:\d{2}\.\d{3}")


def parse_vtt(vtt: str) -> str:
    """Parse WebVTT into clean, deduplicated plain text."""
    out: list[str] = []
    prev: str | None = None
    for raw in vtt.splitlines():
        line = raw.strip()
        if not line:
            continue
        if line.startswith("WEBVTT") or line.startswith("NOTE") or line.startswith("Kind:") \
                or line.startswith("Language:") or TIMESTAMP_LINE_RE.match(line):
            continue
        if line.isdigit():  # cue identifier
            continue
        line = VTT_TAG_RE.sub("", line)
        line = re.sub(r"\s+", " ", line).strip()
        if line and line != prev:
            out.append(line)
            prev = line
    return "\n".join(out)


def detect_lang(filename: str) -> str:
    # yt-dlp names files like "<id>.<lang>.<ext>"; pick the lang segment
    parts = filename.split(".")
    return parts[-2] if len(parts) >= 3 else "unknown"


def fetch(url: str, langs: list[str], tmp: Path) -> Path:
    cmd = [
        "yt-dlp",
        "--write-auto-sub",
        "--write-sub",
        "--sub-langs", ",".join(langs),
        "--sub-format", "vtt",
        "--skip-download",
        "--no-warnings",
        "--no-playlist",
        "--output", str(tmp / "%(id)s.%(ext)s"),
        url,
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        sys.stderr.write(result.stderr or "yt-dlp failed\n")
        raise SystemExit(2)
    vtt_files = sorted(tmp.glob("*.vtt"))
    if not vtt_files:
        raise SystemExit(3)
    # Pick the first file in requested priority order
    for lang in langs:
        for f in vtt_files:
            if f".{lang}." in f.name:
                return f
    return vtt_files[0]


def main() -> None:
    p = argparse.ArgumentParser(description="Extract clean transcript from a YouTube URL.")
    p.add_argument("url", help="YouTube video URL")
    p.add_argument("langs", nargs="?", default="id,en",
                   help="Comma-separated language priority (default: id,en)")
    p.add_argument("-o", "--output", help="Write transcript to file instead of stdout")
    args = p.parse_args()

    langs = [s.strip() for s in args.langs.split(",") if s.strip()]
    with tempfile.TemporaryDirectory() as td:
        tmp = Path(td)
        vtt = fetch(args.url, langs, tmp)
        text = parse_vtt(vtt.read_text(encoding="utf-8"))
        lang = detect_lang(vtt.name)
        sys.stderr.write(f"# source: {vtt.name} (lang={lang}, bytes={len(text)})\n")
        if args.output:
            Path(args.output).write_text(text, encoding="utf-8")
            sys.stderr.write(f"# saved: {args.output}\n")
        else:
            sys.stdout.write(text)
            sys.stdout.write("\n")


if __name__ == "__main__":
    main()
