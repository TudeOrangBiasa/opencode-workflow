{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "engineering-lead",
  "agent": {
    "engineering-lead": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash"
    },
    "frontend-dev": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash"
    },
    "backend-dev": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "skills": {
    "paths": [
      "./skills"
    ]
  }
}
