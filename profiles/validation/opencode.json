{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_KEY}"
      },
      "models": {
        "claude-fable-5": {},
        "gpt-5.6-sol": {},
        "claude-sonnet-5": {},
        "gpt-5.6-terra": {}
      }
    }
  },
  "default_agent": "validation-lead",
  "agent": {
    "validation-lead": {
      "mode": "primary",
      "model": "9router/gpt-5.6-terra",
      "prompt": "{file:./agents/validation-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "qa-engineer": "allow",
          "security-reviewer": "allow",
          "explore": "allow"
        },
        "websearch": "deny",
        "webfetch": "deny",
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "caveman": "allow",
          "design-skill": "allow",
          "ai-regression-testing": "allow",
          "tdd": "allow",
          "code-review": "allow",
          "diagnosing-bugs": "allow",
          "verify-evidence": "allow",
          "click-path-audit": "allow",
          "error-handling": "allow",
          "production-audit": "allow",
          "team-handoff-quality": "allow",
          "dependency-audit": "allow",
          "skill-spector": "allow",
          "php-review": "allow",
          "security-review": "allow",
          "security-bounty-hunter": "allow",
          "defi-amm-security": "allow",
          "evm-token-decimals": "allow",
          "nodejs-keccak256": "allow",
          "prediction-market-risk-review": "allow"
        }
      }
    },
    "qa-engineer": {
      "mode": "subagent",
      "model": "9router/gpt-5.6-terra",
      "prompt": "{file:./agents/qa-engineer.md}",
      "permission": {
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "design-skill": "allow",
          "ai-regression-testing": "allow",
          "tdd": "allow",
          "code-review": "allow",
          "diagnosing-bugs": "allow",
          "verify-evidence": "allow",
          "click-path-audit": "allow",
          "error-handling": "allow",
          "production-audit": "allow",
          "team-handoff-quality": "allow",
          "dependency-audit": "allow",
          "php-review": "allow"
        }
      }
    },
    "security-reviewer": {
      "mode": "subagent",
      "model": "9router/gpt-5.6-terra",
      "prompt": "{file:./agents/security-reviewer.md}",
      "permission": {
        "9router-web-search": "allow",
        "9router-web-fetch": "allow",
        "skill": {
          "skill-spector": "allow",
          "security-review": "allow",
          "security-bounty-hunter": "allow",
          "defi-amm-security": "allow",
          "evm-token-decimals": "allow",
          "nodejs-keccak256": "allow",
          "prediction-market-risk-review": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "browser-use": {
      "type": "local",
      "command": ["/home/todayz/.local/share/opencode/browser-use-venv/bin/mcp-browser-use"],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md", "../../CODING_STANDARDS.md"],
  "skills": { "paths": ["./skills"] }
}
