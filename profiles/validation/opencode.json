{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "validation-lead",
  "agent": {
    "validation-lead": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./agents/validation-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "qa-engineer": "allow",
          "security-reviewer": "allow",
          "explore": "allow"
        }
      }
    },
    "qa-engineer": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "prompt": "{file:./agents/qa-engineer.md}"
    },
    "security-reviewer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./agents/security-reviewer.md}"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md"],
  "skills": {
    "paths": [
      "./skills"
    ]
  }
}
