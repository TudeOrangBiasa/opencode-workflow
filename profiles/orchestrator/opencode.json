{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode/hy3-free",
      "prompt": "{file:./agents/orchestrator.md}",
      "permission": {
        "task": {
          "*": "deny",
          "explore": "allow",
          "scout": "allow"
        },
        "skill": {
          "memory-dreaming": "allow",
          "workflow-audit": "allow",
          "eval": "allow",
          "codebase-onboarding": "allow",
          "context-budget": "allow",
          "deployment-patterns": "allow",
          "git-workflow": "allow",
          "github-ops": "allow",
          "herdr": "allow",
          "search-first": "allow",
          "skill-author": "allow",
          "setup-matt-pocock-skills": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md"],
  "skills": { "paths": ["./skills"] }
}
