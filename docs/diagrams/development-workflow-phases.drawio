<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Development Workflow Phases" id="dev-workflow">
    <mxGraphModel dx="2000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="OpenCode Workflow — Development Phase Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Phase 1: Intake -->
        <mxCell id="phase1" value="PHASE 1: INTAKE" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="300" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p1_request" value="User Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="phase1">
          <mxGeometry x="70" y="50" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p1_orch" value="orchestrator receives" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="phase1">
          <mxGeometry x="70" y="110" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p1_triage" value="Triage: clear/fuzzy?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="phase1">
          <mxGeometry x="90" y="170" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1_grill" value="grill-with-docs&#xa;(if fuzzy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="phase1">
          <mxGeometry x="30" y="230" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p1_plan" value="planner&#xa;(if complex)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="phase1">
          <mxGeometry x="170" y="230" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- Phase 1 edges -->
        <mxCell id="pe1_1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" edge="1" source="p1_request" target="p1_orch" parent="phase1">
          <mxGeometry relative="1" as="geometry" />
