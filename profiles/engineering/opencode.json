{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "engineering-lead",
  "agent": {
    "engineering-lead": {
      "mode": "primary",
      "model": "opencode/hy3-free",
      "prompt": "{file:./agents/engineering-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "frontend-dev": "allow",
          "backend-dev": "allow",
          "explore": "allow"
        },
        "skill": { "*": "allow" }
      }
    },
    "frontend-dev": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "prompt": "{file:./agents/frontend-dev.md}"
    },
    "backend-dev": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./agents/backend-dev.md}"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md"],
  "skills": {
    "paths": [
      "./skills"
    ]
  }
}
