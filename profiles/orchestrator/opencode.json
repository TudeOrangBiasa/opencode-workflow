{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode/hy3-free",
      "prompt": "{file:./agents/orchestrator.md}",
      "permission": {
        "task": {
          "*": "deny",
          "explore": "allow",
          "scout": "allow"
        }
      }
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md"],
  "skills": {
    "paths": [
      "./skills"
    ]
  }
}
