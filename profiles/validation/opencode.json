{
  "default_agent": "validation-lead",
  "agent": {
    "validation-lead": {
      "mode": "primary",
      "model": "9router/oc/hy3-free"
    },
    "qa-engineer": {
      "mode": "subagent",
      "model": "9router/oc/hy3-free"
    },
    "security-reviewer": {
      "mode": "subagent",
      "model": "9router/oc/hy3-free"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "skills": {
    "paths": ["./skills"]
  }
}
