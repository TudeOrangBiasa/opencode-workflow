        <mxCell id="pf4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#9673a6;" edge="1" source="phase4" target="phase5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Feedback loop from Phase 5 to Phase 3 -->
        <mxCell id="pf_feedback" value="Fix &amp; Retry (max 1x)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;fontSize=11;" edge="1" source="p5_fail" target="phase3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1580" y="400" />
              <mxPoint x="910" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Bottom: Key Principles -->
        <mxCell id="principles_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="1740" height="180" as="geometry" />
        </mxCell>
        <mxCell id="principles_title" value="Key Principles" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="430" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="Cheap-first: cheap models for exploration &amp; execution, expensive for planning, routing, review" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Max 3 subagents per request: prevents runaway costs, batch or escalate if more needed" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="No nested subagents: escalate to orchestrator for re-routing" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="60" y="530" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="Real project output: PRs, commits, ADRs, verified tests over agent-to-agent handoffs" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="Anti-tech-debt: every slice leaves codebase no worse than found" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="600" y="470" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="Scope freeze: ask user before adding cleanup, optimization, or tangential changes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p7" value="AFK safety: checkpoint after each slice, detect stuck loops, human checkpoints for irreversible actions" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="600" y="530" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p8" value="Verify-evidence: tool-based verification for non-trivial changes, AFK, flaky tests, explicit AC" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="600" y="560" width="600" height="25" as="geometry" />
        </mxCell>

      </root>
