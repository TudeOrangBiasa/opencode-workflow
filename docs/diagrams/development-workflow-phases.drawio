        <mxCell id="pe1_2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" edge="1" source="p1_orch" target="p1_triage" parent="phase1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe1_3" value="Fuzzy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;fontSize=10;" edge="1" source="p1_triage" target="p1_grill" parent="phase1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe1_4" value="Complex" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;fontSize=10;" edge="1" source="p1_triage" target="p1_plan" parent="phase1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 2: Explore -->
        <mxCell id="phase2" value="PHASE 2: EXPLORE" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="300" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p2_direct" value="Direct read/grep&#xa;(known files)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="phase2">
          <mxGeometry x="30" y="50" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_explore" value="explore&#xa;(codebase unknowns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="phase2">
          <mxGeometry x="160" y="50" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_scout" value="scout&#xa;(external docs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="phase2">
          <mxGeometry x="30" y="120" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_ov" value="OpenViking&#xa;(past decisions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="phase2">
          <mxGeometry x="160" y="120" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_browser" value="browser-qa&#xa;(runtime truth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="phase2">
          <mxGeometry x="90" y="190" width="110" height="50" as="geometry" />
        </mxCell>

        <!-- Phase 3: Implement -->
        <mxCell id="phase3" value="PHASE 3: IMPLEMENT" style="swimlane;startSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="760" y="80" width="300" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p3_builder" value="builder&#xa;(narrow code edits)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="phase3">
          <mxGeometry x="80" y="50" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p3_ac" value="Acceptance criteria&#xa;+ constraints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="phase3">
          <mxGeometry x="30" y="120" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p3_status" value="Status check&#xa;DONE / BLOCKED" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="phase3">
          <mxGeometry x="140" y="120" width="110" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3_retry" value="Retry once&#xa;(if failed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="phase3">
          <mxGeometry x="80" y="220" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- Phase 3 edges -->
        <mxCell id="pe3_1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;" edge="1" source="p3_builder" target="p3_ac" parent="phase3">
