{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "validation-lead",
  "agent": {
    "validation-lead": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./agents/validation-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "qa-engineer": "allow",
          "security-reviewer": "allow",
          "explore": "allow"
        },
        "skill": {
          "ai-regression-testing": "allow",
          "tdd": "allow",
          "code-review": "allow",
          "diagnosing-bugs": "allow",
          "verify-evidence": "allow",
          "click-path-audit": "allow",
          "error-handling": "allow",
          "production-audit": "allow",
          "team-handoff-quality": "allow",
          "php-review": "allow",
          "security-review": "allow",
          "security-bounty-hunter": "allow",
          "defi-amm-security": "allow",
          "evm-token-decimals": "allow",
          "nodejs-keccak256": "allow",
          "prediction-market-risk-review": "allow"
        }
      }
    },
    "qa-engineer": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "prompt": "{file:./agents/qa-engineer.md}",
      "permission": {
        "skill": {
          "ai-regression-testing": "allow",
          "tdd": "allow",
          "code-review": "allow",
          "diagnosing-bugs": "allow",
          "verify-evidence": "allow",
          "click-path-audit": "allow",
          "error-handling": "allow",
          "production-audit": "allow",
          "team-handoff-quality": "allow",
          "php-review": "allow"
        }
      }
    },
    "security-reviewer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./agents/security-reviewer.md}",
      "permission": {
        "skill": {
          "security-review": "allow",
          "security-bounty-hunter": "allow",
          "defi-amm-security": "allow",
          "evm-token-decimals": "allow",
          "nodejs-keccak256": "allow",
          "prediction-market-risk-review": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md"],
  "skills": { "paths": ["./skills"] }
}
