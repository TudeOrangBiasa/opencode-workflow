{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "planning-lead",
  "agent": {
    "planning-lead": {
      "mode": "primary",
      "model": "opencode-go/qwen3.7-plus",
      "prompt": "{file:./agents/planning-lead.md}",
      "permission": {
        "task": {
          "*": "deny",
          "product-manager": "allow",
          "ux-researcher": "allow",
          "explore": "allow"
        },
        "skill": {
          "triage": "allow",
          "to-spec": "allow",
          "to-tickets": "allow",
          "wayfinder": "allow",
          "ask-matt": "allow",
          "grilling": "allow",
          "grill-with-docs": "allow",
          "handoff": "allow",
          "write-a-skill": "allow",
          "deep-research": "allow",
          "research": "allow",
          "architecture-decision-records": "allow",
          "improve-codebase-architecture": "allow",
          "domain-modeling": "allow",
          "teach": "allow"
        }
      }
    },
    "product-manager": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "prompt": "{file:./agents/product-manager.md}",
      "permission": {
        "skill": {
          "to-spec": "allow",
          "to-tickets": "allow",
          "handoff": "allow",
          "write-a-skill": "allow"
        }
      }
    },
    "ux-researcher": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "prompt": "{file:./agents/ux-researcher.md}",
      "permission": {
        "skill": {
          "deep-research": "allow",
          "research": "allow",
          "handoff": "allow"
        }
      }
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "instructions": ["./rules/agents.md"],
  "skills": { "paths": ["./skills"] }
}
