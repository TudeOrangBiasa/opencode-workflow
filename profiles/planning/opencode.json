{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "planning-lead",
  "agent": {
    "planning-lead": {
      "mode": "primary",
      "model": "opencode/hy3-free"
    },
    "product-manager": {
      "mode": "subagent",
      "model": "opencode/hy3-free"
    },
    "ux-researcher": {
      "mode": "subagent",
      "model": "opencode/hy3-free"
    }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    }
  },
  "skills": {
    "paths": ["./skills"]
  },
  "skill_triggers": {
    "triage": ["triage", "triage issue", "triage PR", "agent brief", "classify issue"],
    "to-spec": ["write spec", "specification", "buat spec", "create spec"],
    "to-tickets": ["break tickets", "create tickets", "buat ticket", "split into tickets"],
    "wayfinder": ["plan huge chunk", "investigation tickets", "foggy effort", "chart a path"],
    "ask-matt": ["which skill", "what fits", "what should I use"],
    "grilling": ["grill me", "stress-test plan", "challenge assumptions", "grill"],
    "grill-with-docs": ["grill with docs", "validate against docs", "check against domain"],
    "handoff": ["handoff", "transfer context", "context compaction", "pass to another agent"],
    "write-a-skill": ["create skill", "write skill", "new skill"],
    "deep-research": ["deep research", "multi-source research", "competitive analysis", "thorough research"],
    "research": ["research", "investigate", "look into", "find out about"],
    "architecture-decision-records": ["ADR", "architectural decision", "record this decision", "why did we"],
    "improve-codebase-architecture": ["improve architecture", "refactor architecture", "codebase architecture", "deepening"],
    "domain-modeling": ["domain model", "ubiquitous language", "domain term", "bounded context"],
    "teach": ["teach me", "I want to learn", "explain this concept", "tutorial"]
  }
}
