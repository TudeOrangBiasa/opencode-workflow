{
  "$schema": "https://opencode.ai/config.json",

  // Copy this template into ~/.config/opencode/opencode.json or merge it manually.
  // Do not commit real provider API keys.
  // Replace model ids with the exact ids exposed by `opencode models`.

  "default_agent": "orchestrator",

  // Default conversation model. Pick one strong reasoning model.
  // Recommended candidates for orchestrator:
  // - mimo-v2.5-pro
  // - kimi-k2.6
  // - deepseek-v4-pro
  // - qwen-3.7
  // - minimax-m3
  // - glm-5.1
  // - gpt-5.5
  "model": "opencode-go/minimax-m3",

  // Cheap/free model for bounded execution and exploration.
  "small_model": "opencode/deepseek-v4-flash-free",

  "plugin": ["caveman"],

  "skills": {
    "paths": [
      ".opencode/skills",
      "~/.config/opencode/skills"
    ]
  },

  // Optional modules such as OpenViking can be enabled in personal config.
  // If OpenViking MCP is absent, agents should continue with local files only.

  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode-go/minimax-m3",
      "permission": {
        "task": {
          "*": "deny",
          "builder": "allow",
          "reviewer": "allow",
          "browser-qa": "allow",
          "explore": "allow",
          "scout": "allow"
        }
      },
      // Skill auto-load triggers: keywords that fire skill load before delegation.
      // Edit this when adding new auto-loadable skills.
      "skill_triggers": {
        "officecli": ["docx", "pptx", "xlsx", "laporan", "spreadsheet", "presentation"],
        "ponytail": ["review", "audit", "yagni", "over-engineer", "simple", "minimal", "refactor"],
        "diagnose": ["bug", "broken", "error", "crash", "slow", "regression"],
        "tdd": ["implement", "feature", "test-first", "red-green"],
        "verify-evidence": ["ship", "ship it", "done", "is it done", "finish", "finished", "merge", "pr ready", "deploy", "deploy it", "push to prod", "release", "cut release", "tag release", "/ship", "/ship-it", "/yeet"],
        "impeccable": [
          "ui", "frontend", "layout", "design", "polish", "visual", "ux",
          "impeccable teach", "impeccable document", "impeccable craft",
          "impeccable audit", "impeccable critique", "impeccable adapt",
          "impeccable live", "impeccable polish", "impeccable bolder",
          "impeccable quieter", "impeccable colorize", "impeccable optimize",
          "impeccable harden", "impeccable typeset", "impeccable delight",
          "impeccable distill", "impeccable clarify", "impeccable shape",
          "impeccable extract", "impeccable onboard", "impeccable overdrive"
        ],
        "emil-design-eng": ["motion", "animation", "easing", "spring", "transition", "gesture"],
        "design-system": ["design system", "design tokens", "style guide"],
        "ui-to-vue": ["vue", "convert to vue", "vue component"],
        "review-animations": ["review motion", "review animation", "animation review"],
        "php-review": ["php", "laravel", "blade", "eloquent"],
        "security-review": ["auth", "secret", "password", "credential", "vulnerability"]
      }
    },

    "builder": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free"
    },

    "reviewer": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "permission": {
        "edit": "deny"
      },
      "skill_triggers": {
        "ponytail": ["review", "audit", "yagni", "over-engineer", "simple", "minimal"]
      }
    },

    "browser-qa": {
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },

    "explore": {
      // Built-in OpenCode subagent. Keep prompt built-in; tune only model/permissions here.
      // Use for current local repo discovery.
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny"
      }
    },

    "scout": {
      // Built-in OpenCode subagent. Keep prompt built-in; tune only model/permissions here.
      // Use for external docs/dependency source research.
      // mimo is multimodal — good for reading docs/screenshots with images.
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "edit": "deny"
      }
    },

    "compaction": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.1
    },

    // Optional: disable built-ins you do not use as primaries.
    "general": { "disable": true },
    "plan": { "disable": true },
    "build": { "disable": true }
  },

  "mcp": {
    // Web research. Useful for scout/planner/orchestrator when docs or current web context matter.
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },

    // Browser/runtime evidence. Required for browser-qa full-page sweeps, console/network checks, screenshots.
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },

    // Optional memory/RAG. Workflow must continue if this is absent or disabled.
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    },

    // Office document tool. Required for .docx/.xlsx/.pptx work.
    // Install: curl -fsSL https://raw.githubusercontent.com/iOfficeAI/OfficeCLI/main/install.sh | bash
    // Path is absolute to avoid PATH resolution conflicts with the unrelated
    // npm "officecli" package (officecli.io / delaym, generation-only API tool).
    "officecli": {
      "type": "local",
      "command": [
        "/home/todayz/.local/bin/officecli",
        "mcp"
      ],
      "enabled": true
    }
  }
}
