{
  "$schema": "https://opencode.ai/config.json",

  // Copy template into ~/.config/opencode/opencode.json or merge manually.
  // Do not commit real provider API keys.
  // Replace model ids with the exact ids exposed by `opencode models`.

  "default_agent": "planner",

  // Default conversation model. Pick strong reasoning model.
  "model": "opencode-go/minimax-m3",

  // Cheap/free model for bounded execution and exploration.
  "small_model": "opencode/deepseek-v4-flash-free",

  "plugin": ["caveman"],

  "skills": {
    "paths": [
      ".opencode/skills",
      "~/.config/opencode/skills"
    ]
  },

  "agent": {
    "planner": {
      "mode": "primary",
      "model": "opencode-go/minimax-m3",
      "permission": {
        "task": {
          "*": "deny",
          "builder": "allow",
          "reviewer": "allow",
          "advisor": "allow",
          "explore": "allow",
          "scout": "allow"
        }
      },
      "skill_triggers": {
        "officecli": ["docx", "pptx", "xlsx", "laporan", "spreadsheet", "presentation"],
        "document-writing": ["laporan", "dokumen", "docx", "bab", "extend", "tambah bab", "skripsi", "thesis", "academic"],
        "ponytail": ["review", "audit", "yagni", "over-engineer", "simple", "minimal", "refactor"],
        "diagnosing-bugs": ["bug", "broken", "error", "crash", "slow", "regression"],
        "tdd": ["implement", "feature", "test-first", "red-green"],
        "verify-evidence": ["ship", "done", "is it done", "finish", "merge", "pr ready", "deploy", "release", "/ship", "/yeet"],
        "openviking": ["memory", "remember", "openviking", "store", "retrieve", "task", "fix", "implement", "build", "create", "update", "modify", "refactor", "add", "find"],
        "humanizer": ["write", "edit", "draft", "readme", "docs", "laporan", "dokumen", "essay", "paper", "artikel", "bab", "prose", "narasi", "summarize", "explain", "caption"],
        "design": ["ui", "frontend", "layout", "design", "polish", "visual", "ux", "motion", "animation", "easing", "transition", "gesture"],
        "design-system": ["design system", "design tokens", "style guide"],
        "ui-to-vue": ["vue", "convert to vue", "vue component"],
        "review-animations": ["review motion", "review animation", "animation review"],
        "php-review": ["php", "laravel", "blade", "eloquent"],
        "security-review": ["auth", "secret", "password", "credential", "vulnerability"]
      }
    },

    "builder": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free"
    },

    "reviewer": {
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "*": "allow",
        "edit": "deny"
      }
    },

    "advisor": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "permission": {
        "edit": "deny",
        "task": "deny"
      }
    },

    "explore": {
      // Built-in OpenCode subagent. Keep prompt built-in; tune only model/permissions.
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny"
      }
    },

    "scout": {
      // Built-in OpenCode subagent. Keep prompt built-in.
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny"
      }
    },

    "compaction": {
      "temperature": 0.1
    },

    // Optional: disable built-ins you do not use as primaries.
    "general": { "disable": true },
    "plan": { "disable": true },
    "build": { "disable": true },
    "orchestrator": { "disable": true },
    "validator": { "disable": true }
  },

  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "openviking": {
      "type": "remote",
      "url": "http://localhost:1933/mcp",
      "enabled": true
    },
    "officecli": {
      "type": "local",
      "command": ["/home/todayz/.local/bin/officecli", "mcp"],
      "enabled": true
    }
  }
}
